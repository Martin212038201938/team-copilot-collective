# Environment Configuration
# Copy this file to .env for local development

# Node Environment
NODE_ENV=production

# Application URL
VITE_APP_URL=https://copilotenschule.de

# API Configuration (if needed in the future)
# VITE_API_URL=https://api.copilotenschule.de
# VITE_API_KEY=your_api_key_here

# Analytics (if needed in the future)
# VITE_GA_TRACKING_ID=your_google_analytics_id
# VITE_GTM_ID=your_google_tag_manager_id

# Feature Flags (if needed in the future)
# VITE_ENABLE_FEATURE_X=true
